  <section class="tech-container py-5">
    <div class="container py-5">
      <h2 class="text-center fw-bold mb-5">Como Construímos o <span class="hw-last">Projeto</span></h2>
      <div class="row g-4 justify-content-center">
        <div class="col-md-6 col-lg-4">
          <div class="tech-card">
            <h6 class="fw-bold mb-3">Web</h6>
            <div class="d-flex align-items-start gap-3">
              <span class="tech-icon flex-shrink-0"><i class="bi bi-code-slash"></i></span>
