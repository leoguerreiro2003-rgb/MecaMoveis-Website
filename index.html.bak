          <h6 class="mt-3 mb-1">Leandro <span class="hw-last">Pinto</span></h6>
          <small class="text-white">Desenvolvedor de Software</small>
        </div>
        <div class="col-6 col-md-4 col-lg-3">
          <img class="team-photo" src="assets/foto_filipev.jpg" alt="Filipe Viegas">
          <h6 class="mt-3 mb-1">Filipe <span class="hw-last">Viegas</span></h6>
          <small class="text-white">Desenvolvedor de Software</small>
        </div>
      </div>
    </div>
